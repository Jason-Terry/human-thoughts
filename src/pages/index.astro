---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

function getPreview(body: string | undefined): string {
  if (!body) return '';
  const marker = '<!-- preview -->';
  const parts = body.split(marker).slice(1);
  if (parts.length === 0) return marked.parse(body.slice(0, 600)) as string;
  const pick = parts[Math.floor(Math.random() * parts.length)];
  return marked.parse(pick.slice(0, 600)) as string;
}

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Home">
  <div class="post-list">
    {posts.map((post) => (
      <a href={`/posts/${post.id}`} class="post-card">
        <time datetime={post.data.date.toISOString().split('T')[0]}>
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <h2>{post.data.title}</h2>
        <div class="post-preview">
          <Fragment set:html={getPreview(post.body)} />
          <div class="preview-fade" />
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .post-list {
    max-width: var(--content-max-width);
    margin: 2rem auto;
    padding: 0 2rem;
  }

  .post-card {
    display: block;
    background-color: var(--bg-paper);
    color: var(--text-paper);
    padding: 2rem 2.5rem;
    margin-bottom: 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .post-card time {
    font-size: 0.8rem;
    opacity: 0.5;
    display: block;
    margin-bottom: 0.4rem;
  }

  .post-card h2 {
    font-family: 'Fraunces', serif;
    font-weight: 800;
    font-size: 1.5rem;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .post-description {
    font-size: 0.95rem;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .post-preview {
    position: relative;
    max-height: 120px;
    overflow: hidden;
    font-size: 0.88rem;
    line-height: 1.6;
    opacity: 0.55;
  }

  .preview-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--bg-paper));
    pointer-events: none;
  }

  @media (max-width: 800px) {
    .post-list {
      padding: 0 5%;
    }

    .post-card {
      padding: 1.5rem;
    }
  }
</style>
