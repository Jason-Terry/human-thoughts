---
import BaseLayout from './BaseLayout.astro';
import AuthorCard from '../components/AuthorCard.astro';

interface Props {
  title: string;
  date: Date;
}

const { title, date } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title}>
  <article>
    <div class="paper">
      <header class="post-header">
        <time datetime={date.toISOString().split('T')[0]}>{formattedDate}</time>
        <h1>{title}</h1>
      </header>
      <div class="post-content">
        <slot />
      </div>
      <AuthorCard />
      <div class="giscus-wrapper">
        <script
          src="https://giscus.app/client.js"
          data-repo="Jason-Terry/human-thoughts"
          data-repo-id="R_kgDORwISEw"
          data-category="General"
          data-category-id="DIC_kwDORwISE84C5QL9"
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme="https://human-thoughts.blog/giscus-theme.css"
          data-lang="en"
          crossorigin="anonymous"
          async
        ></script>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-header time {
    font-size: 0.85rem;
    opacity: 0.6;
    display: block;
    margin-bottom: 0.5rem;
  }

  .giscus-wrapper {
    margin-top: 3rem;
  }
</style>
